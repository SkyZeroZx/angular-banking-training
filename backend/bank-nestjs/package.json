{
  "name": "backend-bank-nestjs",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Bank NestJS monolith using an in-memory database.",
  "scripts": {
    "build": "nest build",
    "deploy:worker": "wrangler deploy",
    "dev:worker": "wrangler dev",
    "dry-run:worker": "wrangler deploy --dry-run",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "types:worker": "wrangler types"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.27",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260707.1",
    "@nestjs/cli": "^11.0.23",
    "typescript": "^6.0.3",
    "wrangler": "^4.108.0"
  }
}
